{
    "name": "clone",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "start:server": "node --watch server.js",
        "start:client": "bash -lc 'set -a; source .env; set +a; vite --host \"$DB_HOST\"'",
        "dev": "concurrently \"pnpm:start:*\"",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d dist"
    },
    "dependencies": {
        "axios": "^1.16.0",
        "concurrently": "^9.2.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "lucide-react": "^1.14.0",
        "pg": "^8.20.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.15.0",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.3.0",
        "vite": "^8.0.10"
    }
}